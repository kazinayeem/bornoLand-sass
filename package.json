{
  "name": "bornoland",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "concurrently -n web,api -c cyan,magenta \"corepack pnpm --filter @bornoland/web dev\" \"corepack pnpm --filter @bornoland/api dev\"",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write .",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3"
  }
}